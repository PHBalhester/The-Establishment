.env
.env.mainnet

# Anchor/Rust build artifacts
target/
.anchor/

# Node.js
node_modules/
dist/

# Deployment artifacts (generated at runtime, contain secrets)
scripts/deploy/mint-keypairs/

# Mainnet keypairs — NEVER commit these
keypairs/mainnet-*
scripts/deploy/pda-manifest.json
scripts/deploy/pda-manifest.md
scripts/deploy/deploy-log-*.txt

# Next.js app build artifacts
app/.next/
# IDL files ARE committed (needed for Railway builds where anchor build hasn't run)

# Local validator state (contains keypairs + rocksdb)
test-ledger/

# E2E test run logs
scripts/e2e/*.jsonl
scripts/e2e/*.log

# BOK verification worktree (multi-GB Kani/test artifacts)
.bok/worktree/

# Original unoptimized PNGs (optimized WebPs live in app/public/scene/)
WebsiteAssets/
# === Dev certificates ===
app/certificates/
*.pem

# === Internal tooling archive variants ===
.dbs-archive-*/
